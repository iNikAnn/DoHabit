{
	"name": "dohabit",
	"description": "DoHabit is a straightforward habit tracker that doesn’t require registration. Easily mark your completed days, track your progress, and keep a journal for each habit.",
	"private": true,
	"version": "0.40.0",
	"homepage": "https://inikann.github.io/DoHabit/",
	"type": "module",
	"scripts": {
		"type-check": "tsc -b",
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "eslint .",
		"lint:css": "stylelint '**/*.css'",
		"preview": "vite preview",
		"predeploy": "npm run build",
		"deploy": "gh-pages -b gh-pages -d dist"
	},
	"dependencies": {
		"@uidotdev/usehooks": "^2.4.1",
		"chart.js": "^4.5.1",
		"clsx": "^2.1.1",
		"es-toolkit": "^1.46.1",
		"framer-motion": "^12.40.0",
		"html2canvas-pro": "^2.0.2",
		"react": "^19.2.0",
		"react-chartjs-2": "^5.3.1",
		"react-dom": "^19.2.0",
		"react-error-boundary": "^6.1.1",
		"react-icons": "^5.6.0",
		"react-router": "^7.15.1",
		"react-textarea-autosize": "^8.5.9",
		"sonner": "^2.0.7",
		"zustand": "^5.0.13"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^24.6.2",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"@vite-pwa/assets-generator": "^1.0.2",
		"@vitejs/plugin-react": "^6.0.2",
		"eslint": "^10.4.0",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"gh-pages": "^6.3.0",
		"globals": "^17.6.0",
		"stylelint": "^17.12.0",
		"stylelint-config-recess-order": "^7.7.0",
		"stylelint-config-standard": "^40.0.0",
		"stylelint-order": "^8.1.1",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.59.4",
		"vite": "^8.0.10",
		"vite-plugin-pwa": "^1.3.0",
		"vite-plugin-svgr": "^5.2.0",
		"workbox-core": "^7.4.1",
		"workbox-window": "^7.4.1"
	},
	"overrides": {
		"sharp": "^0.33.5",
		"sharp-ico": "^0.1.5"
